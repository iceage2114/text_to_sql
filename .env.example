# GitHub Personal Access Token with Models read permission
# Create at: https://github.com/settings/tokens  (no scopes needed for public models)
GITHUB_TOKEN=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

# ─── SQL Server Express Connection String ───────────────────────────────────
# Pick ONE of the formats below and set it as MSSQL_CONN_STR.
#
# FORMAT A — Raw ODBC string (easiest: copy straight from SSMS)
#   Windows Authentication (most common for local SQL Express):
#     MSSQL_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=JONATHANS-PC\SQLEXPRESS;DATABASE=AdventureWorks2019;Trusted_Connection=yes
#
#   SQL Server Authentication:
#     MSSQL_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=JONATHANS-PC\SQLEXPRESS;DATABASE=AdventureWorks2019;UID=sa;PWD=YourPassword
#
# FORMAT B — SQLAlchemy URL  (backslash in instance name must be encoded as %5C)
#   Windows Authentication:
#     MSSQL_CONN_STR=mssql+pyodbc://@JONATHANS-PC%5CSQLEXPRESS/AdventureWorks2019?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
#
#   SQL Server Authentication:
#     MSSQL_CONN_STR=mssql+pyodbc://sa:YourPassword@JONATHANS-PC%5CSQLEXPRESS/AdventureWorks2019?driver=ODBC+Driver+17+for+SQL+Server
#
# NOTE: If using ODBC Driver 18 (instead of 17), append to either format:
#   raw ODBC:         ;TrustServerCertificate=yes
#   SQLAlchemy URL:   &TrustServerCertificate=yes
# ────────────────────────────────────────────────────────────────────────────
MSSQL_CONN_STR=DRIVER={ODBC Driver 17 for SQL Server};SERVER=JONATHANS-PC\SQLEXPRESS;DATABASE=AdventureWorks2019;Trusted_Connection=yes

CHROMA_PATH=./chroma_data
ROW_LIMIT=500
MAX_RETRIES=3
CRITIC_THRESHOLD=0.6
TOOL_TIMEOUT_SECONDS=10
RETROSPECTIVE_FAILURE_LIMIT=100
